    // The swarm acts as a prediction market. They "bet" their phase on the correct weights.
    let market_result = mirofish_bridge::arkhe_swarm_predict({
        hypothesis: "Find W_L such that Associator [Ψ_out, Ψ_target, W_L*Ψ_in] == 0",
        swarm_size: 64
